# ==========================================
# RAG Backend 环境变量配置
# 滑动窗口记忆版本
# ==========================================

# === LLM 配置 ===
RAGENT_LLM_MODEL=gpt-4o
OPENAI_API_KEY=your_openai_key_here

# === Checkpointer 配置（二选一）===
# 方案 1: PostgreSQL（推荐生产环境）
# RAGENT_POSTGRES_URL=postgresql://user:password@localhost:5432/ragent

# 方案 2: SQLite（本地开发）
RAGENT_SQLITE_PATH=checkpoints.sqlite

# === MySQL 归档存储配置 ===
RAGENT_MYSQL_HOST=127.0.0.1
RAGENT_MYSQL_PORT=3306
RAGENT_MYSQL_USER=root
RAGENT_MYSQL_PASSWORD=your_password
RAGENT_MYSQL_DATABASE=ragent
RAGENT_MYSQL_CHARSET=utf8mb4

# === 记忆管理配置 ===
# 触发压缩的消息阈值（超过此数量会压缩）
RAGENT_MAX_MESSAGES=20
# 压缩后保留的最近消息数
RAGENT_KEEP_RECENT=4

# === 服务器配置 ===
RAGENT_PORT=8000
RAGENT_DEBUG=false

# === MCP 配置（如有） ===
# RAGENT_MCP_SERVER_URL=http://localhost:8001
