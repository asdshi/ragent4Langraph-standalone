# ==========================================
# RAG Backend 环境变量配置
# 滑动窗口记忆版本
# ==========================================
BASE_URL：https://dashscope.aliyuncs.com/compatible-mode/v1
# === LLM 配置 ===
# 以下环境变量可覆盖 config/settings.yaml 中的 llm 配置
RAGENT_LLM_PROVIDER=openai
RAGENT_LLM_MODEL=qwen3.5-omni-flash
RAGENT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# RAGENT_LLM_API_KEY=your-api-key-here
# RAGENT_LLM_TEMPERATURE=0.0
# RAGENT_LLM_MAX_TOKENS=4096
OPENAI_API_KEY=sk-d0b1eb180cb246ad8ea32580f0791a9f

# === Embedding 配置 ===
# 以下环境变量可覆盖 config/settings.yaml 中的 embedding 配置
# RAGENT_EMBEDDING_PROVIDER=openai
# RAGENT_EMBEDDING_MODEL=text-embedding-v3
# RAGENT_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# RAGENT_EMBEDDING_API_KEY=your-api-key-here
# RAGENT_EMBEDDING_DIMENSIONS=1536

# === Vision LLM 配置 ===
# 以下环境变量可覆盖 config/settings.yaml 中的 vision_llm 配置
# RAGENT_VISION_LLM_ENABLED=true
# RAGENT_VISION_LLM_PROVIDER=openai
# RAGENT_VISION_LLM_MODEL=qwen3.5-omni-flash
# RAGENT_VISION_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# RAGENT_VISION_LLM_API_KEY=your-api-key-here
# RAGENT_VISION_LLM_MAX_IMAGE_SIZE=2048

# === Checkpointer 配置（二选一）===
# 方案 1: PostgreSQL（推荐生产环境）
# RAGENT_POSTGRES_URL=postgresql://user:password@localhost:5432/ragent

# 方案 2: SQLite（本地开发）
RAGENT_SQLITE_PATH=checkpoints.sqlite

# === MySQL 归档存储配置 ===
RAGENT_MYSQL_HOST=127.0.0.1
RAGENT_MYSQL_PORT=3306
RAGENT_MYSQL_USER=root
RAGENT_MYSQL_PASSWORD=xzs1329490380
RAGENT_MYSQL_DATABASE=ragent
RAGENT_MYSQL_CHARSET=utf8mb4

# === 记忆管理配置 ===
# 触发压缩的消息阈值（超过此数量会压缩）
RAGENT_MAX_MESSAGES=20
# 压缩后保留的最近消息数
RAGENT_KEEP_RECENT=4

# === 服务器配置 ===
RAGENT_PORT=8000
RAGENT_DEBUG=false

# === MCP 配置（如有） ===
# RAGENT_MCP_SERVER_URL=http://localhost:8001
