# ==========================================
# RAG Backend 环境变量配置
# Agent 层统一 PostgreSQL 版本
# ==========================================

# === LLM 配置 ===
RAGENT_LLM_PROVIDER=openai
RAGENT_LLM_MODEL=qwen3.5-omni-flash
RAGENT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=your-api-key-here

# === Embedding 配置 ===
# RAGENT_EMBEDDING_PROVIDER=openai
# RAGENT_EMBEDDING_MODEL=text-embedding-v3
# RAGENT_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# === Vision LLM 配置 ===
# RAGENT_VISION_LLM_ENABLED=true
# RAGENT_VISION_LLM_PROVIDER=openai
# RAGENT_VISION_LLM_MODEL=qwen3.5-omni-flash

# === Agent 层存储配置（PostgreSQL，必需）===
RAGENT_POSTGRES_URL=postgresql://user:password@localhost:5432/ragent

# === IG 层存储配置（SQLite，本地文件指纹）===
RAGENT_SQLITE_PATH=checkpoints.sqlite

# === 记忆管理配置 ===
RAGENT_MAX_MESSAGES=20
RAGENT_KEEP_RECENT=4

# === 服务器配置 ===
RAGENT_PORT=8000
RAGENT_DEBUG=false
